# Credmax - Configuracao
# Copie este arquivo para .env e altere os valores

# Chave secreta para tokens JWT (obrigatorio)
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_aqui

# Senha do usuario admin (padrao: admin123)
# Em producao, defina uma senha forte
# ADMIN_PASSWORD=sua_senha_forte

# Banco de dados (padrao: SQLite local)
# Em producao com PostgreSQL:
# DATABASE_URL=postgresql://usuario:senha@host:5432/credmax

# Porta do servidor (padrao: 8000)
# PORT=8000

# Modo reload para desenvolvimento (padrao: false)
# RELOAD=true
